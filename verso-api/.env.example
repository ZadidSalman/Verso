# ─────────────────────────────────────────────────────────────────────────────
# Verso Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/verso
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/verso
MONGODB_URI=mongodb://localhost:27017/verso

# ── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me

# ── Brevo (Email / OTP) ─────────────────────────────────────────────────────
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=zadidsalman@gmail.com
BREVO_SENDER_NAME=Verso

# ── Development ──────────────────────────────────────────────────────────────
# Set to "true" to log OTP codes to console instead of sending emails
ENABLE_DEV_OTP_LOG=true
