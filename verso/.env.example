# ─────────────────────────────────────────────────────────────────────────────
# Verso Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# These are passed via --dart-define at build time, NOT as a .env file.
# Copy this file to .env for local reference only.

# ── Backend API URL ──────────────────────────────────────────────────────────
# Local emulator:  http://10.0.2.2:3000
# Local physical device:  http://<your-lan-ip>:3000
# Production:  https://api.verso.app
API_URL=http://10.0.2.2:3000

# ── Firebase (FCM — required for push notifications) ────────────────────────
# Add your google-services.json to verso/android/app/
# These are NOT needed for local development if you skip FCM.
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=

# ── Pusher (Real-time — Phase 3+) ───────────────────────────────────────────
# PUSHER_KEY=
# PUSHER_CLUSTER=ap2

# ── Sentry (Crash reporting — Phase 9+) ─────────────────────────────────────
# SENTRY_DSN=

# ── PostHog (Analytics — Phase 9+) ──────────────────────────────────────────
# POSTHOG_KEY=
